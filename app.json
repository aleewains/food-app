{
  "expo": {
    "name": "food-app",
    "slug": "food-app",
    "scheme": "food-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "cover",
      "backgroundColor": "#FCFCFD",
      "dark": {
        "image": "./assets/splash.png",
        "backgroundColor": "#0F1117"
      }
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.alonejack.foodapp"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-splash-screen",
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "158d0540-22a3-44a7-b13a-2aad6f251cbe"
      }
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/158d0540-22a3-44a7-b13a-2aad6f251cbe"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
